{
  "name": "js-act",
  "version": "1.0.1",
  "description": "Lightweight SSR-first frontend library with fine-grained signals and island architecture",
  "type": "module",
  "main": "./dist/actjs.cjs.js",
  "module": "./dist/actjs.esm.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "actjs": "bin/actjs.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/actjs.esm.js",
      "require": "./dist/actjs.cjs.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/actjs.server.esm.js"
    },
    "./vite": {
      "types": "./dist/vite-plugin.d.ts",
      "import": "./dist/vite-plugin.js",
      "require": "./dist/vite-plugin.cjs.js"
    }
  },
  "peerDependencies": {},
  "peerDependenciesMeta": {},
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "unpkg": "./dist/actjs.iife.js",
  "jsdelivr": "./dist/actjs.iife.js",
  "sideEffects": false,
  "dependencies": {
    "esbuild": "^0.25.0",
    "ws": "^8.18.0"
  },
  "scripts": {
    "build": "vite build && vite build --config vite.iife.config.ts && node scripts/patch-jsx-runtime-dts.mjs",
    "build:dev": "node scripts/build-dev.mjs",
    "build:create": "node scripts/build-create.mjs",
    "build:all": "npm run build && npm run build:dev && npm run build:create",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "format": "prettier --write src tests",
    "dev:counter": "node bin/actjs.js --entry examples/counter/index.html --port 3000",
    "dev:todo": "node bin/actjs.js --entry examples/todo/index.html --port 3001",
    "dev:blog": "node bin/actjs.js --entry examples/blog/index.html --port 3002",
    "dev:landing": "node bin/actjs.js --entry examples/landing/index.html --port 3003"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "^4.0.18",
    "happy-dom": "^20.8.3",
    "typescript": "^5.5.0",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "frontend",
    "signals",
    "ssr",
    "islands",
    "reactive"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vaisakhrkrishnan/actjs.git"
  }
}
