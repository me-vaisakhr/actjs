{
  "compilerOptions": {
    "target": "ES2018",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2018", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "js-act",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "noEmit": true,
    "skipLibCheck": true,
    "paths": {
      "js-act": ["./src/index.ts"],
      "js-act/jsx-runtime": ["./src/jsx-runtime.ts"],
      "js-act/server": ["./src/hydration.ts"]
    }
  },
  "include": ["src", "tests"],
  "exclude": ["node_modules", "dist"]
}
